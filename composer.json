{
    "name": "mihari/logger",
    "description": "Log collection and transport library for PHP",
    "type": "library",
    "license": "MIT",
    "keywords": ["logging", "log", "transport", "mihari", "monolog"],
    "homepage": "https://github.com/mihari/logger-php",
    "require": {
        "php": ">=8.1",
        "psr/log": "^3.0",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-zlib": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "monolog/monolog": "^3.0"
    },
    "suggest": {
        "monolog/monolog": "Required for MonologHandler integration (^3.0)"
    },
    "autoload": {
        "psr-4": {
            "Mihari\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mihari\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    }
}
